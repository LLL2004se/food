{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "backend/**/*.js",
    "scripts/**/*.mjs",
    "Ai/**/*.py"
  ],
  "exclude": [
    "node_modules",
    "backend/node_modules",
    "dist"
  ]
}